    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('register status is success', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('register returns timestamps', function () {",
                  "    pm.expect(json.createdAt).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.updatedAt).to.be.a('string').and.not.empty;",
                  "});",
                  "if (json && json.id) {",
                  "    pm.environment.set('pendingUserId', json.id);",
                  "}",
                  "if (json && json.residenceCode) {",
                  "    pm.environment.set('residenceCode', json.residenceCode);",
                  "}",
                  "if (json && json.createdAt) {",
                  "    pm.environment.set('pendingUserCreatedAt', json.createdAt);",
                  "}",
                  "if (json && json.updatedAt) {",
                  "    pm.environment.set('pendingUserUpdatedAt', json.updatedAt);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{pendingUserEmail}}\",\n  \"password\": \"{{pendingUserPassword}}\",\n  \"residenceCode\": \"{{residenceCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login Active User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('login status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json && json.token) {",
                  "    pm.environment.set('userToken', json.token);",
                  "    pm.environment.set('userId', json.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{pendingUserEmail}}\",\n  \"password\": \"{{pendingUserPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
